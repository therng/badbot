{
  "name": "analytic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "esbuild src/worker/index.ts --bundle --platform=node --target=node20 --external:@prisma/client --outfile=dist/worker.js",
    "parse:mt5-report": "node --import tsx scripts/parse-mt5-reports.ts",
    "start": "mkdir -p .next/standalone/.next/static .next/standalone/public && cp -R .next/static/. .next/standalone/.next/static/ && cp -R public/. .next/standalone/public/ && node .next/standalone/server.js",
    "lint": "eslint .",
    "worker": "npm run build:worker && node dist/worker.js",
    "worker:dev": "ts-node src/worker/index.ts",
    "worker:once": "npm run build:worker && WORKER_RUN_ONCE=true node dist/worker.js",
    "worker:reimport": "npm run build:worker && WORKER_RUN_ONCE=true WORKER_FORCE_REIMPORT=true node dist/worker.js",
    "worker:reimport:local": "npm run build:worker && REPORT_SOURCE=local WORKER_RUN_ONCE=true WORKER_FORCE_REIMPORT=true node dist/worker.js",
    "db:clean": "node --import tsx scripts/cleanup.ts",
    "db:backfill-report-results": "node --import tsx scripts/backfill-report-results.ts",
    "db:remediate-positions": "node --import tsx scripts/remediate-corrupt-positions.ts",
    "test:formatters": "node --import tsx --test src/components/trading-monitor/DashboardFormatters.test.ts",
    "test:parser": "node --import tsx --test src/lib/parser/index.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "basic-ftp": "^5.3.0",
    "cheerio": "^1.2.0",
    "next": "^15.5.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "browserslist": {
    "production": [
      "ios_saf >= 16",
      "safari >= 16",
      "chrome >= 109",
      "edge >= 109",
      "firefox >= 115"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
