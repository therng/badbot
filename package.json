{
  "name": "badbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "esbuild src/worker/index.ts --bundle --platform=node --target=node20 --external:@prisma/client --outfile=dist/worker.js",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "worker": "npm run build:worker && node dist/worker.js",
    "worker:dev": "ts-node src/worker/index.ts",
    "worker:once": "npm run build:worker && WORKER_RUN_ONCE=true node dist/worker.js",
    "worker:reimport": "npm run build:worker && WORKER_RUN_ONCE=true WORKER_FORCE_REIMPORT=true node dist/worker.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "basic-ftp": "^5.2.0",
    "bullmq": "^5.71.0",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
