generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TradingAccount {
  id                  String               @id @default(cuid())
  accountNo           String               @unique @map("account_number")
  accountName         String?              @map("owner_name")
  company             String?
  currency            String
  serverName          String               @map("server")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  reportDate          DateTime?            @map("report_date")
  accountReportResult AccountReportResult?
  accountSnapshot     AccountSnapshot?
  deals               Deal[]
  openPositions       OpenPosition[]
  positions           Position[]
  reportImports       ReportImport[]

  @@map("Account")
}

model AccountReportResult {
  id                         String         @id @default(cuid())
  tradingAccountId           String         @unique @map("account_id")
  computedAt                 DateTime       @default(now()) @map("computed_at")
  sourceReportDate           DateTime?      @map("source_report_date")
  totalCommission            Decimal?       @map("total_commission") @db.Decimal(28, 8)
  totalSwap                  Decimal?       @map("total_swap") @db.Decimal(28, 8)
  totalNetProfit             Decimal?       @map("total_net_profit") @db.Decimal(28, 8)
  grossProfit                Decimal?       @map("gross_profit") @db.Decimal(28, 8)
  grossLoss                  Decimal?       @map("gross_loss") @db.Decimal(28, 8)
  profitFactor               Float?         @map("profit_factor")
  expectedPayoff             Decimal?       @map("expected_payoff") @db.Decimal(28, 8)
  recoveryFactor             Float?         @map("recovery_factor")
  sharpeRatio                Float?         @map("sharpe_ratio")
  balanceDrawdownAbsolute    Decimal?       @map("balance_drawdown_absolute") @db.Decimal(28, 8)
  balanceDrawdownMaximal     Decimal?       @map("balance_drawdown_maximal") @db.Decimal(28, 8)
  balanceDrawdownMaximalPct  Float?         @map("balance_drawdown_maximal_pct")
  balanceDrawdownRelativePct Float?         @map("balance_drawdown_relative_pct")
  balanceDrawdownRelative    Decimal?       @map("balance_drawdown_relative") @db.Decimal(28, 8)
  totalTrades                Int?           @map("total_trades")
  shortTradesWon             Int?           @map("short_trades_won")
  shortTradesTotal           Int?           @map("short_trades_total")
  longTradesWon              Int?           @map("long_trades_won")
  longTradesTotal            Int?           @map("long_trades_total")
  profitTradesCount          Int?           @map("profit_trades_count")
  lossTradesCount            Int?           @map("loss_trades_count")
  largestProfitTrade         Decimal?       @map("largest_profit_trade") @db.Decimal(28, 8)
  largestLossTrade           Decimal?       @map("largest_loss_trade") @db.Decimal(28, 8)
  averageProfitTrade         Decimal?       @map("average_profit_trade") @db.Decimal(28, 8)
  averageLossTrade           Decimal?       @map("average_loss_trade") @db.Decimal(28, 8)
  maximumConsecutiveWins     Int?           @map("maximum_consecutive_wins")
  maximumConsecutiveLosses   Int?           @map("maximum_consecutive_losses")
  tradingAccount             TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  @@index([computedAt])
  @@map("AccountReportResult")
}

model AccountSnapshot {
  id               String         @id @default(cuid())
  tradingAccountId String         @unique @map("account_id")
  sourceFileName   String?        @map("source_file_name")
  balance          Decimal        @db.Decimal(28, 8)
  creditFacility   Decimal        @default(0) @map("credit_facility") @db.Decimal(28, 8)
  floatingPl       Decimal        @map("floating_pl") @db.Decimal(28, 8)
  equity           Decimal        @db.Decimal(28, 8)
  freeMargin       Decimal        @map("free_margin") @db.Decimal(28, 8)
  margin           Decimal        @db.Decimal(28, 8)
  marginLevel      Float?         @map("margin_level")
  reportDate       DateTime       @map("report_date")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  @@map("AccountSnapshot")
}

model OpenPosition {
  id               String         @id @default(cuid())
  tradingAccountId String         @map("account_id")
  positionNo       String         @map("position_no")
  openTime         DateTime?      @map("open_time")
  symbol           String
  type             String
  volume           Float
  price            Decimal        @db.Decimal(28, 8)
  sl               Decimal?       @db.Decimal(28, 8)
  tp               Decimal?       @db.Decimal(28, 8)
  marketPrice      Decimal        @map("market_price") @db.Decimal(28, 8)
  swap             Decimal        @default(0) @db.Decimal(28, 8)
  profit           Decimal        @default(0) @db.Decimal(28, 8)
  comment          String?
  reportDate       DateTime       @map("report_date")
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  @@unique([tradingAccountId, positionNo])
  @@index([tradingAccountId, symbol])
  @@index([tradingAccountId, reportDate])
  @@map("OpenPosition")
}

model Position {
  id               String         @id @default(cuid())
  tradingAccountId String         @map("account_id")
  positionNo       String         @map("position_no")
  symbol           String
  type             String
  volume           Float
  openTime         DateTime?      @map("open_time")
  openPrice        Decimal?       @map("open_price") @db.Decimal(28, 8)
  sl               Decimal?       @db.Decimal(28, 8)
  tp               Decimal?       @db.Decimal(28, 8)
  closeTime        DateTime?      @map("close_time")
  closePrice       Decimal?       @map("close_price") @db.Decimal(28, 8)
  commission       Decimal        @default(0) @db.Decimal(28, 8)
  swap             Decimal        @default(0) @db.Decimal(28, 8)
  profit           Decimal        @default(0) @db.Decimal(28, 8)
  comment          String?
  reportDate       DateTime       @map("report_date")
  importedAt       DateTime       @default(now()) @map("imported_at")
  pips             Float?
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  @@unique([tradingAccountId, positionNo])
  @@index([tradingAccountId, closeTime])
  @@index([tradingAccountId, openTime])
  @@index([tradingAccountId, reportDate])
  @@map("Position")
}

model Deal {
  id               String         @id @default(cuid())
  tradingAccountId String         @map("account_id")
  dealNo           String         @map("deal_no")
  time             DateTime
  symbol           String?
  type             String
  direction        String?
  volume           Float?
  price            Decimal?       @db.Decimal(28, 8)
  commission       Decimal        @default(0) @db.Decimal(28, 8)
  fee              Decimal        @default(0) @db.Decimal(28, 8)
  swap             Decimal        @default(0) @db.Decimal(28, 8)
  profit           Decimal        @default(0) @db.Decimal(28, 8)
  balance          Decimal?       @db.Decimal(28, 8)
  comment          String?
  reportDate       DateTime       @map("report_date")
  importedAt       DateTime       @default(now()) @map("imported_at")
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  @@unique([tradingAccountId, dealNo])
  @@index([tradingAccountId, time])
  @@index([tradingAccountId, reportDate])
  @@index([tradingAccountId, type])
  @@index([symbol])
  @@map("Deal")
}

model ReportImport {
  id               String         @id @default(cuid())
  tradingAccountId String         @map("account_id")
  fileName         String         @map("file_name")
  fileHash         String         @map("file_hash")
  reportDate       DateTime       @map("report_date")
  createdAt        DateTime       @default(now()) @map("created_at")
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  @@unique([tradingAccountId, fileHash])
  @@index([tradingAccountId])
  @@index([reportDate])
  @@map("ReportImport")
}
